PORT=3232
BASE_URI=https://your-tunnel-url.trycloudflare.com
NODE_ENV=production
BLOCKED_COMMANDS=

# Redis (optional — omit to use in-memory session store)
# REDIS_URL=redis://localhost:6379

# Authorization PIN (optional)
# If set, this fixed PIN is used every time — convenient for auto-restart setups.
# If not set, a random 8-char PIN is generated on each startup,
# saved to ~/.rcmcp/.pin (chmod 600), and shown via macOS notification.
# SERVER_PIN=yourFixedPin
